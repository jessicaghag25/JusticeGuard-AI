# Backend server port for Replit or local execution
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Use a long random secret in production.
JWT_SECRET=replace_with_a_long_random_secret

# JWT lifetime in seconds (example: 1 hour)
JWT_EXPIRES_IN=3600

# Storage mode: local (default) or s3
STORAGE_MODE=local

# Local upload folder (used when STORAGE_MODE=local)
UPLOAD_DIR=uploads

# Optional S3 settings (used when STORAGE_MODE=s3)
AWS_REGION=us-east-1
S3_BUCKET=your-96ply-bucket
AWS_ACCESS_KEY_ID=replace_me
AWS_SECRET_ACCESS_KEY=replace_me

# Optional OpenAI settings (if missing, local rule engine is used)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
